pipeline {
  triggers {
    pollSCM ('H/3 * * * *')
  }
  options {
    disableConcurrentBuilds()
  }
  environment {
        //DOMAIN='apps.ocp4.example.com'
        DOMAIN='apps.cluster-dev.klaverviertjes.nl'
        PRJ="gitops-gitops-${env.BRANCH_NAME}-${env.BUILD_NUMBER}"
        APP='gitops-gitops'
       PATH = "/usr/bin:${env.PATH}"
    }
  agent {
    node{
      label 'nodejs'
    }
  }
  stages {
    stage ('Validate configuration resources') {
      steps {
       echo sh(script: 'env|sort', returnStdout: true)
       sh 'oc login -u josk -p redhat --insecure-skip-tls-verify https://api.cluster-dev.klaverviertjes.nl:6443' 
       sh 'oc apply --dry-run=client -k config'

      }
    }
    stage ('Apply resources') {
      when{
        branch 'main'
      }
      steps {
        sh 'oc apply -k config'
        sh './wait_oauth.sh'
      }
    }
    stage ('Verify test user') {
      when{
	branch 'main'
      }
      steps {
        sh 'oc login -u testuser -p redhat123 --insecure-skip-tls-verify https://kubernetes.default.svc:443'
        sh 'oc new-project test-testuser || true'
      }
    }
  }
}
