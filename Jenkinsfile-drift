pipeline {
  triggers {
  cron('H/5 * * * *')
  }
  environment {
         //DOMAIN='apps.ocp4.example.com'
        DOMAIN='apps.cluster-dev.klaverviertjes.nl'
        PRJ="gitops-gitops-${env.BRANCH_NAME}-${env.BUILD_NUMBER}"
        APP='gitops-gitops'
        PATH = "/usr/bin:${env.PATH}"
         
  }  

  agent {
    node {
      label 'nodejs'
    }
  }
  stages {
    stage ('Check resource drift') {
      steps {
         sh 'oc login --server=https://api.cluster-dev.klaverviertjes.nl:6443 --token=sha256~IBVRYBAPBeLkiLwBlYvwoAIet4FjnDcbSjdr6I_RLyw'
        sh 'oc whoami'
        sh 'oc diff -k config | tee drift-report.txt'
        sh '! test -s drift-report.txt'
      }
    }
  }
  post {
    failure {
     archiveArtifacts artifacts: '*.txt'
     build job: 'apply/main'
    }
    success {
    sh 'rm drift-report.txt'
    sh 'echo \'There is no configuration drift!\'' > no-drift.txt
    archiveArtifacts artifacts: '*.txt'
    }
  }
}
